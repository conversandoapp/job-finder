# --- Supabase (autenticación — OBLIGATORIO, sin esto no arranca el login) ---
# Project Settings → API Keys → Project URL
# El backend también usa esto para verificar tokens (JWKS), no hace falta
# ningún secreto extra en proyectos nuevos de Supabase.
SUPABASE_URL=
# Project Settings → API Keys → "anon public" (o "publishable key" en
# proyectos nuevos, empieza con sb_publishable_...). Es pública, se expone
# al frontend a propósito — la seguridad la da la verificación del token.
SUPABASE_ANON_KEY=
# Legacy / opcional: solo hace falta si tu proyecto todavía firma los JWT
# con el secreto compartido HS256 (Project Settings → JWT Keys → pestaña
# "Legacy JWT Secret"). Los proyectos creados desde octubre de 2025 firman
# de forma asimétrica y NO necesitan esto — dejalo vacío.
SUPABASE_JWT_SECRET=
# El email de la ÚNICA cuenta que va a tener acceso al panel admin.
# Tiene que ser el mismo email con el que te registrás en /admin-login.html.
ADMIN_EMAIL=conversandoapp@gmail.com

# --- Notificaciones por email (opcional para probar local) ---
# Dejar en false para que las notificaciones queden solo en
# backend/storage/notifications.log y en el panel admin.
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_FROM=conversandoapp@gmail.com
NOTIFY_EMAIL_TO=conversandoapp@gmail.com
# App Password de 16 caracteres generada en https://myaccount.google.com/apppasswords
NOTIFY_EMAIL_APP_PASSWORD=

# --- Google Drive (opcional para probar local) ---
# Dejar en false para que los CVs se guarden solo en
# backend/storage/sessions/{session_id}/cv_original.*
DRIVE_ENABLED=false
DRIVE_CREDENTIALS_PATH=backend/credentials/service_account.json
DRIVE_FOLDER_ID=
