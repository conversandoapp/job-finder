# --- Supabase (autenticación — OBLIGATORIO, sin esto no arranca el login) ---
# Project Settings → API Keys → Project URL
# El backend también usa esto para verificar tokens (JWKS), no hace falta
# ningún secreto extra en proyectos nuevos de Supabase.
SUPABASE_URL=
# Project Settings → API Keys → "anon public" (o "publishable key" en
# proyectos nuevos, empieza con sb_publishable_...). Es pública, se expone
# al frontend a propósito — la seguridad la da la verificación del token.
SUPABASE_ANON_KEY=
# Legacy / opcional: solo hace falta si tu proyecto todavía firma los JWT
# con el secreto compartido HS256 (Project Settings → JWT Keys → pestaña
# "Legacy JWT Secret"). Los proyectos creados desde octubre de 2025 firman
# de forma asimétrica y NO necesitan esto — dejalo vacío.
SUPABASE_JWT_SECRET=
# El email de la ÚNICA cuenta que va a tener acceso al panel admin.
# Tiene que ser el mismo email con el que te registrás en /admin-login.html.
ADMIN_EMAIL=conversandoapp@gmail.com
# Secreto — NUNCA lo mandes al frontend. Project Settings → API Keys →
# "service_role" (no la "anon public"). El backend lo usa para leer/escribir
# en Postgres y Storage con privilegios completos — la autorización real la
# sigue haciendo el backend en Python (auth.py), no RLS. Ver
# backend/supabase/schema.sql para el esquema que hay que correr una vez.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la app (se usa en los links de los emails de notificación).
# Si no se configura, usa https://job-finder-scwk.onrender.com por defecto.
APP_BASE_URL=https://job-finder-scwk.onrender.com

# --- Notificaciones por email (opcional para probar local) ---
# Dejar en false para que las notificaciones queden solo en la tabla
# `notifications` de Supabase y en el panel admin.
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_FROM=conversandoapp@gmail.com
NOTIFY_EMAIL_TO=conversandoapp@gmail.com
# App Password de 16 caracteres generada en https://myaccount.google.com/apppasswords
NOTIFY_EMAIL_APP_PASSWORD=

# --- Google Drive (opcional, requiere el servicio ya desplegado) ---
# Dejar en false para que los CVs se guarden solo en Supabase Storage (bucket
# "cv-files") — Drive acá es solo una copia extra de conveniencia para el admin.
# Setup: ver "Activar Google Drive real" en README.md
DRIVE_ENABLED=false
# ID de cliente OAuth tipo "Aplicación web" (Google Cloud Console →
# Credenciales → Crear credenciales → ID de cliente de OAuth)
DRIVE_OAUTH_CLIENT_ID=
DRIVE_OAUTH_CLIENT_SECRET=
# URL pública del servicio desplegado + /api/admin/drive/oauth2callback
DRIVE_OAUTH_REDIRECT_URI=
# Opcional: ID de una carpeta de Drive puntual. Si se deja vacío, la app
# busca o crea automáticamente una carpeta "Job Finder - CVs recibidos".
DRIVE_FOLDER_ID=
